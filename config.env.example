# Optional local overrides for rz-rpc-llm.
# Copy to config.env and uncomment ONLY the values you need to change.
# Everything else is inherited from defaults.env — do NOT copy the full file.
# Model-specific settings (threads, ctx, sampling) live in models.conf.
# Set sensitive values like Hugging Face tokens in your shell, not in project files.
# Any override is reported at startup so drift is visible.

# --- DGX connection ---
# DGX_HOST="192.168.88.66"
# DGX_USER="your_user"
# DGX_REMOTE_DIR="/home/your_user/rz-rpc-llm/llama.cpp"

# --- Network ---
# LLAMA_BACKEND_PORT=8682
# MONITOR_WEB_PORT=8680

# --- Global performance ---
# LLAMA_DEFRAG_THOLD=0.05
# LLAMA_CACHE_REUSE=64
