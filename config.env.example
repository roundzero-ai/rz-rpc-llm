# ==============================================================================
# rz-rpc-llm Configuration
# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit secrets.
# ==============================================================================

# --- DGX Spark GB10 (RPC backend, CUDA) ---
DGX_HOST="192.168.86.242"
DGX_USER="user"
DGX_REMOTE_DIR="/home/user/rz-rpc-llm/llama.cpp"
DGX_RPC_PORT=50052
DGX_RPC_BIND="0.0.0.0"
# Path to CUDA bin on DGX — SSH sessions don't source .bashrc so nvcc is not
# in PATH by default. Adjust if CUDA is installed elsewhere (e.g. /usr/local/cuda-12.8/bin).
DGX_CUDA_BIN="/usr/local/cuda/bin"

# --- Mac Studio M2 Ultra (llama-server, Metal) ---
# Local paths (relative to project root or absolute)
LLAMA_CPP_DIR="./llama.cpp"
MODELS_DIR="./models"

# llama-server listen settings
LLAMA_HOST="0.0.0.0"
LLAMA_PORT=8680

# --- Model defaults ---
# Hugging Face token (or set HF_TOKEN in your shell)
HF_TOKEN="hf_REPLACE_ME"

# Default HF repo and file glob for download
DEFAULT_MODEL_REPO="unsloth/MiniMax-M2.5-GGUF"
DEFAULT_MODEL_PATTERN="*UD-Q6_K_XL*"

# First GGUF file (used as --model argument to llama-server)
DEFAULT_MODEL_FILE="UD-Q6_K_XL/MiniMax-M2.5-UD-Q6_K_XL-00001-of-00005.gguf"
DEFAULT_MODEL_ALIAS="minimax-m2.5"

# --- llama-server inference parameters ---
LLAMA_CTX_SIZE=131072
LLAMA_PARALLEL=4
LLAMA_THREADS=14
LLAMA_THREADS_BATCH=20
LLAMA_BATCH_SIZE=8192
LLAMA_UBATCH_SIZE=2048
LLAMA_N_GPU_LAYERS="all"
LLAMA_TENSOR_SPLIT="2,3"
LLAMA_SPLIT_MODE="layer"
LLAMA_TEMP=1.0
LLAMA_TOP_P=0.95
LLAMA_TOP_K=40
LLAMA_MIN_P=0.01
LLAMA_REPEAT_PENALTY=1.0
LLAMA_PRIO=3
LLAMA_CACHE_TYPE_K="q8_0"
LLAMA_CACHE_TYPE_V="q8_0"
LLAMA_CACHE_REUSE=256
