# Optional local overrides for rz-rpc-llm.
# Copy to config.env only if you want to override checked-in defaults from defaults.env.
# Set sensitive values like Hugging Face tokens in your shell, not in project files.

# Common local overrides:
# DGX_HOST="192.168.86.242"
# DGX_USER="your_user"
# DGX_REMOTE_DIR="/home/your_user/rz-rpc-llm/llama.cpp"
# LLAMA_BACKEND_PORT=8682
# MONITOR_WEB_HOST="0.0.0.0"
# MONITOR_WEB_PORT=8680

# Example model/runtime overrides:
# DEFAULT_MODEL_FILE="UD-Q6_K_XL/MiniMax-M2.5-UD-Q6_K_XL-00001-of-00005.gguf"
# DEFAULT_VISION_MODEL_FILE="UD-Q6_K_XL/Qwen3.5-122B-A10B-UD-Q6_K_XL-00001-of-00004.gguf"
# LLAMA_TEXT_CTX_SIZE=131072
# LLAMA_VISION_CTX_SIZE=262144
# LLAMA_VISION_PARALLEL=4
# LLAMA_DEFRAG_THOLD=0.05
