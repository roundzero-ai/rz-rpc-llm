# ==============================================================================
# rz-rpc-llm Default Configuration
# Checked into git: keep this file non-sensitive.
# Override locally in config.env or through shell environment variables.
# ==============================================================================

# --- DGX Spark GB10 (RPC backend, CUDA) ---
DGX_HOST="192.168.86.242"
DGX_USER="user"
DGX_REMOTE_DIR="/home/user/rz-rpc-llm/llama.cpp"
DGX_RPC_PORT=50052
DGX_RPC_BIND="0.0.0.0"
DGX_CUDA_BIN="/usr/local/cuda/bin"

# --- Mac Studio M2 Ultra (llama-server, Metal) ---
LLAMA_CPP_DIR="./llama.cpp"
MODELS_DIR="./models"

# llama-server listen settings
# Public API / monitor gateway
LLAMA_HOST="0.0.0.0"
LLAMA_PORT=8680

# Internal llama-server backend (proxied by the monitor gateway)
LLAMA_BACKEND_HOST="127.0.0.1"
LLAMA_BACKEND_PORT=8682

MONITOR_WEB_HOST="0.0.0.0"
MONITOR_WEB_PORT=8680

# --- Model defaults ---
# Text-only model (distributed across Mac + DGX via RPC)
DEFAULT_MODEL_REPO="unsloth/MiniMax-M2.5-GGUF"
DEFAULT_MODEL_PATTERN="*UD-Q6_K_XL*"
DEFAULT_MODEL_FILE="UD-Q6_K_XL/MiniMax-M2.5-UD-Q6_K_XL-00001-of-00005.gguf"
DEFAULT_MODEL_ALIAS="minimax-m2.5"

# Vision model (Qwen3.5-122B — runs solo on Mac Studio, no DGX RPC needed)
DEFAULT_VISION_REPO="unsloth/Qwen3.5-122B-A10B-GGUF"
DEFAULT_VISION_MODEL_PATTERN="*UD-Q6_K_XL*"
DEFAULT_VISION_MODEL_FILE="UD-Q6_K_XL/Qwen3.5-122B-A10B-UD-Q6_K_XL-00001-of-00004.gguf"
DEFAULT_VISION_MM_PROJ="mmproj-BF16.gguf"
DEFAULT_VISION_ALIAS="qwen3.5-122b-vision"
DEFAULT_MM_PROJ_PATTERN="mmproj*.gguf"

# =============================================================================
# llama-server inference parameters
# =============================================================================

# --- General ---
LLAMA_CTX_SIZE=131072
LLAMA_PARALLEL=1
LLAMA_THREADS=14
LLAMA_THREADS_BATCH=14
LLAMA_BATCH_SIZE=2048
LLAMA_UBATCH_SIZE=512
LLAMA_N_GPU_LAYERS="all"
LLAMA_TENSOR_SPLIT="2,3"
LLAMA_SPLIT_MODE="layer"

# --- Vision model (Mac solo, 128K context) ---
LLAMA_VISION_CTX_SIZE=131072
LLAMA_VISION_PARALLEL=4
LLAMA_VISION_BATCH_SIZE=2048
LLAMA_VISION_UBATCH_SIZE=512
LLAMA_VISION_N_GPU_LAYERS="all"
LLAMA_VISION_SPLIT_MODE="none"

# --- Distributed text defaults (MiniMax-M2.5 recommended) ---
LLAMA_TEXT_TEMP=1.0
LLAMA_TEXT_TOP_P=0.95
LLAMA_TEXT_TOP_K=40
LLAMA_TEXT_MIN_P=0.01
LLAMA_TEXT_REPEAT_PENALTY=1.0
LLAMA_TEXT_PRESENCE_PENALTY=0.0

# --- Vision defaults (Qwen3.5 recommended — client can override via API) ---
LLAMA_TEMP=1.0
LLAMA_TOP_P=0.95
LLAMA_TOP_K=20
LLAMA_MIN_P=0.0
LLAMA_REPEAT_PENALTY=1.0
LLAMA_PRESENCE_PENALTY=1.5
LLAMA_FREQUENCY_PENALTY=0.0

# Coding (thinking mode, lower temp for precision):
LLAMA_TEMP_CODING=0.6
LLAMA_TOP_P_CODING=0.95
LLAMA_TOP_K_CODING=20
LLAMA_PRESENCE_PENALTY_CODING=0.0

# Instruct/non-thinking (direct answers):
LLAMA_TEMP_INSTRUCT=0.7
LLAMA_TOP_P_INSTRUCT=0.8
LLAMA_TOP_K_INSTRUCT=20
LLAMA_PRESENCE_PENALTY_INSTRUCT=1.5

# --- Performance ---
LLAMA_PRIO=3
LLAMA_FLASH_ATTN="on"
LLAMA_CACHE_TYPE_K="q8_0"
LLAMA_CACHE_TYPE_V="q8_0"
LLAMA_CACHE_PROMPT=1
LLAMA_CACHE_RAM=0
LLAMA_CACHE_REUSE=64
LLAMA_CONT_BATCHING=1
LLAMA_NO_CONTEXT_SHIFT=0
LLAMA_DEFRAG_THOLD=0.05

# --- Vision-specific (memory-safe for 192GB Mac Studio) ---
LLAMA_VISION_CACHE_TYPE_K="q8_0"
LLAMA_VISION_CACHE_TYPE_V="q8_0"
