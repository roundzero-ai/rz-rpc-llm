# ==============================================================================
# rz-rpc-llm Default Configuration
# Checked into git: keep this file non-sensitive.
# Override locally in config.env or through shell environment variables.
#
# Model-specific settings (threads, ctx, sampling, etc.) live in models.conf.
# This file contains only infrastructure and global performance settings.
# ==============================================================================

# --- DGX Spark GB10 (RPC backend, CUDA) ---
DGX_HOST="192.168.86.242"
DGX_USER="user"
DGX_REMOTE_DIR="/home/user/rz-rpc-llm/llama.cpp"
DGX_RPC_PORT=50052
DGX_RPC_BIND="0.0.0.0"
DGX_CUDA_BIN="/usr/local/cuda/bin"

# --- Mac Studio M2 Ultra (llama-server, Metal) ---
LLAMA_CPP_DIR="./llama.cpp"
MODELS_DIR="./models"

# Public API / monitor gateway
LLAMA_HOST="0.0.0.0"
LLAMA_PORT=8680

# Internal llama-server backend (proxied by the monitor gateway)
LLAMA_BACKEND_HOST="127.0.0.1"
LLAMA_BACKEND_PORT=8682

MONITOR_WEB_HOST="0.0.0.0"
MONITOR_WEB_PORT=8680

# --- Global performance ---
LLAMA_PRIO=3
LLAMA_FLASH_ATTN="on"
LLAMA_CACHE_PROMPT=1
LLAMA_CACHE_RAM=0
LLAMA_CACHE_REUSE=64
LLAMA_CONT_BATCHING=1
LLAMA_NO_CONTEXT_SHIFT=0
LLAMA_DEFRAG_THOLD=0.05
